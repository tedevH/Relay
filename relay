#!/bin/sh
SCRIPT_PATH=$0
while [ -h "$SCRIPT_PATH" ]; do
  LINK_TARGET=$(readlink "$SCRIPT_PATH")
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH=$LINK_TARGET ;;
    *) SCRIPT_PATH=$(dirname "$SCRIPT_PATH")/"$LINK_TARGET" ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
exec python3 "$SCRIPT_DIR/relay.py" "$@"
